# Python build & bytecode artifacts
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Test / tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Local runtime data (financial-mcp default cache lives in ~/.cache, but a
# repo-local CACHE_DIR or stray SQLite files should never be committed)
*.db
*.sqlite
*.sqlite3

# Security-toolkit hook runtime logs (written into a repo-local .claude/ when
# the hooks run here during testing; never part of the source)
.claude/hooks/logs/

# Editor / OS noise
.DS_Store
*.swp
.idea/
.vscode/
